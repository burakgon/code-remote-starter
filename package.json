  "version": "0.1.0",
  "description": "Start Claude Code sessions in any directory, from your phone.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "code-remote-starter": "dist/server/index.js",
    "crs": "dist/server/index.js"
